<view class="details-view"><view class="order-top"><block wx:if="{{!payment_success}}"><view class="order-remind"><view>{{order_status_message}}</view><view>{{order_status_submessage}}</view></view></block><block wx:else><view class="order-remind"><view>下单成功，坐等开吃</view><view>菜品已在制作中</view></view></block></view><block wx:if="{{!payment_success}}"><view class="food-list"><view class="foot-back"><view class="foot-til"><text>我的购物车</text></view><block wx:for="{{goods_data}}" wx:for-item="item" wx:for-index="index" wx:key="index"><block><view class="foot-deta"><view><image src="{{baseUrl+'/image/dish/'+item.image}}" mode="aspectFill"></image></view><view class="foot-name"><text>{{item.name}}</text><text>{{item.quantity+item.unit}}</text></view><view class="foot-total">{{"¥"+item.total_price}}</view></view></block></block><view class="total-view"><view>{{"共 "+overall+" 份"}}</view><view class="total-price"><text>总计</text><text>{{"¥"+$root.m0}}</text></view></view></view><view class="foot-back order-number"><text>{{"桌台名称："+other_data.table_number}}</text><block wx:if="{{other_data.number_of_diners}}"><text>{{"用餐人数："+other_data.number_of_diners}}</text></block></view><view style="height:300rpx;"></view></view></block><block wx:else><view class="food-list"><view class="foot-back"><view class="foot-til"><text>我的订单</text></view><block wx:for="{{order_info.goods_list}}" wx:for-item="item" wx:for-index="index" wx:key="index"><block><view class="foot-deta"><view><image src="{{baseUrl+'/image/dish/'+item.image}}" mode="aspectFill"></image></view><view class="foot-name"><text>{{item.name}}</text><text>{{item.quantity+item.unit}}</text></view><view class="foot-total">{{"¥"+item.total_price}}</view></view></block></block><view class="total-view"><view>{{"共 "+(order_info.goods_list?$root.g0:0)+" 份"}}</view><view class="total-price"><text>总计</text><text>{{"¥"+$root.m1}}</text></view></view></view><view class="foot-back order-number"><text>{{"订单编号："+order_info.order_no}}</text><text>{{"下单时间："+(order_info.order_time?$root.g1:'')}}</text><text>{{"支付时间："+(order_info.pay_time?$root.g2:'')}}</text><text>{{"桌台名称："+order_info.table_number}}</text><text>{{"用餐人数："+order_info.number_of_diners}}</text><text>{{"派送状态："+(order_info.is_delivered?'已派送':'未派送')}}</text><block wx:if="{{order_info.delivery_time}}"><text>{{"派送时间："+$root.g3}}</text></block><block wx:if="{{order_info.rating}}"><text>{{"用餐评分："+order_info.rating+"分"}}</text></block><block wx:if="{{order_info.comment_time}}"><text>{{"评价时间："+$root.g4}}</text></block><block wx:if="{{order_info.transaction_id}}"><text>{{"交易号："+order_info.transaction_id}}</text></block></view><block wx:if="{{!order_info.rating&&order_info.is_delivered}}"><view class="foot-back"><view class="foot-til"><text>用餐评价</text></view><view class="rating-area"><text>请为本次用餐评分：</text><view class="rating-stars"><block wx:for="{{10}}" wx:for-item="star" wx:for-index="index" wx:key="*this"><text data-event-opts="{{[['tap',[['handleRatingClick',[index+1]]]]]}}" class="{{['star',(index+1<=rating)?'active':'']}}" bindtap="__e">★</text></block></view><view class="comment-area"><text>评价内容：</text><textarea class="comment-input" placeholder="请输入您的评价..." data-event-opts="{{[['input',[['__set_model',['','comment','$event',[]]]]]]}}" value="{{comment}}" bindinput="__e"></textarea></view><view class="rating-btn"><view data-event-opts="{{[['tap',[['submitRating',['$event']]]]]}}" bindtap="__e">提交评价</view></view></view></view></block><block wx:else><block wx:if="{{!order_info.rating&&!order_info.is_delivered}}"><view class="foot-back"><view class="foot-til"><text>用餐评价</text></view><view class="rating-area"><text>管理员尚未派送，派送后可评价</text></view></view></block></block><view style="height:300rpx;"></view></view></block><block wx:if="{{!payment_success}}"><view class="add-a-dish" style="{{'padding-bottom:'+(Modelmes?'68rpx':'')+';'}}"><view class="button-container"><view data-event-opts="{{[['tap',[['continueAdding',['$event']]]]]}}" class="cart-button" bindtap="__e">继续加菜</view><view data-event-opts="{{[['tap',[['handlePayment',['$event']]]]]}}" class="cart-button primary" bindtap="__e">去支付</view></view></view></block><block wx:else><view class="add-a-dish" style="{{'padding-bottom:'+(Modelmes?'68rpx':'')+';'}}"><view data-event-opts="{{[['tap',[['handleButtonClick',['$event']]]]]}}" class="{{[(payment_success&&button_text==='支付成功')?'payment-success-btn':'']}}" bindtap="__e">{{''+button_text+''}}</view></view></block></view>