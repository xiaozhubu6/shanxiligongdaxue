{"remainingRequest":"/Users/zhuqilong/Devlop/APP/saoma-diancan-pc/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/zhuqilong/Devlop/APP/saoma-diancan-pc/src/page/dish-management/dishes-list.vue?vue&type=style&index=0&id=030142a3&lang=css","dependencies":[{"path":"/Users/zhuqilong/Devlop/APP/saoma-diancan-pc/src/page/dish-management/dishes-list.vue","mtime":1749540948819},{"path":"/Users/zhuqilong/Devlop/APP/saoma-diancan-pc/node_modules/css-loader/index.js","mtime":1749404542461},{"path":"/Users/zhuqilong/Devlop/APP/saoma-diancan-pc/node_modules/vue-loader/lib/loaders/stylePostLoader.js","mtime":1749404543121},{"path":"/Users/zhuqilong/Devlop/APP/saoma-diancan-pc/node_modules/postcss-loader/src/index.js","mtime":1749404542874},{"path":"/Users/zhuqilong/Devlop/APP/saoma-diancan-pc/node_modules/cache-loader/dist/cjs.js","mtime":1749404542822},{"path":"/Users/zhuqilong/Devlop/APP/saoma-diancan-pc/node_modules/vue-loader/lib/index.js","mtime":1749404542945}],"contextDependencies":[],"result":["\r\n.tab-list {\r\n\tdisplay: grid;\r\n\tgrid-template-columns: 1fr 1fr 1fr 1fr 1fr 2fr;\r\n\talign-items: center;\r\n\theight: 50px;\r\n\tbackground-color: #f5f5f5;\r\n\tpadding: 0 20px;\r\n}\r\n\r\n.tab-table {\r\n\tdisplay: grid;\r\n\tgrid-template-columns: 1fr 1fr 1fr 1fr 1fr 2fr;\r\n\talign-items: center;\r\n\tpadding: 20px;\r\n\tborder-bottom: 1px solid #eee;\r\n}\r\n\r\n.elimg {\r\n\twidth: 50px;\r\n\theight: 50px;\r\n\tborder-radius: 5px;\r\n}\r\n",{"version":3,"sources":["dishes-list.vue"],"names":[],"mappings":";AA0JA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA","file":"dishes-list.vue","sourceRoot":"src/page/dish-management","sourcesContent":["<template>\r\n\t<div class=\"ordering\" v-loading.fullscreen.lock=\"loading\">\r\n\t\t<div class=\"heading\">菜品管理</div>\r\n\t\t<div class=\"content-view\">\r\n\t\t\t<div class=\"button-view\">\r\n\t\t\t\t<router-link :to=\"{name:'upload'}\">\r\n\t\t\t\t<el-button type=\"success\" size=\"medium\">添加菜品</el-button>\r\n\t\t\t\t</router-link>\r\n\t\t\t</div>\r\n\t\t\t<div v-if=\"nodatas\">\r\n\t\t\t\t<!-- 表头 -->\r\n\t\t\t\t<div class=\"tab-list\">\r\n\t\t\t\t\t<span v-for=\"(item,index) in tablist\" :key=\"index\">{{item}}</span>\r\n\t\t\t\t</div>\r\n\t\t\t\t<!-- 表格 -->\r\n\t\t\t\t<div class=\"tab-table\" v-for=\"(goods_item,index) in tabcont\" :key=\"index\">\r\n\t\t\t\t\t<div>{{goods_item.time}}</div>\r\n\t\t\t\t\t<div>{{goods_item.type.label}}</div>\r\n\t\t\t\t\t<div>{{goods_item.name}}</div>\r\n\t\t\t\t\t<div>\r\n\t\t\t\t\t\t<el-image class=\"elimg\"\r\n\t\t\t\t\t\t:src=\"getServerUrl()+'/image/dish/'+goods_item.image\"\r\n\t\t\t\t\t\tfit=\"cover\"\r\n\t\t\t\t\t\t:lazy=\"true\"\r\n\t\t\t\t\t\t:preview-src-list=\"[getServerUrl()+'/image/dish/'+goods_item.image]\">\r\n\t\t\t\t\t\t</el-image>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t<div>{{goods_item.unitprice}}</div>\r\n\t\t\t\t\t<div>\r\n\t\t\t\t\t\t<el-button size=\"small\" @click=\"edIt(goods_item)\" :disabled=\"goods_item.onsale ? false : true \">编辑</el-button>\r\n\t\t\t\t\t\t<el-button v-if=\"goods_item.onsale\" type=\"danger\" size=\"small\" @click=\"shelf(goods_item.id,false,index)\" :loading=\"index == shelfload ? true : false\" :disabled=\"index == shelfload ? true : false\">不显示</el-button>\r\n\t\t\t\t\t\t<el-button v-else type=\"warning\" size=\"small\"  @click=\"shelf(goods_item.id,true,index)\">显示</el-button>\r\n\t\t\t\t\t\t<el-button type=\"warning\" size=\"small\"  @click=\"deleteDish(goods_item.id)\">删除</el-button>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<!-- 分页 -->\r\n\t\t\t\t<el-pagination\r\n\t\t\t\t\tbackground\r\n\t\t\t\t\tlayout=\"prev, pager, next\"\r\n\t\t\t\t\t:hide-on-single-page=\"true\"\r\n\t\t\t\t\t:total=\"total\"\r\n\t\t\t\t\t@current-change=\"currentchange\"\r\n\t\t\t\t\t>\r\n\t\t\t\t</el-pagination>\r\n\t\t\t</div>\r\n\t\t\t<!-- 没有数据 -->\r\n\t\t\t<div class=\"nodatas\" v-if=\"!nodatas\">还没有菜品数据</div>\r\n\t\t</div>\r\n\t\t<div style=\"height: 120px;\"></div>\r\n\t</div>\r\n</template>\r\n\r\n<script>\r\nimport { getServerUrl, requestUtil } from '@/utils/requestUtil.js'\r\n\r\nexport default {\r\n\tdata() {\r\n\t\treturn {\r\n\t\t\tloading: false,\r\n\t\t\tnodatas: true,\r\n\t\t\ttablist: ['上架时间', '菜品分类', '菜品名称', '菜品图片', '单价', '操作'],\r\n\t\t\ttabcont: [],\r\n\t\t\ttotal: 0,\r\n\t\t\tshelfload: -1\r\n\t\t}\r\n\t},\r\n\tmethods: {\r\n\t\t// 获取菜品列表\r\n\t\tasync getDishList() {\r\n\t\t\ttry {\r\n\t\t\t\tthis.loading = true\r\n\t\t\t\tconst res = await requestUtil({url: \"/dish/list\", method: \"get\"})\r\n\t\t\t\tif(res.code === 0) {\r\n\t\t\t\t\tthis.tabcont = res.data\r\n\t\t\t\t\tthis.total = this.tabcont.length\r\n\t\t\t\t}\r\n\t\t\t} catch(error) {\r\n\t\t\t\tconsole.error(\"获取菜品列表失败:\", error)\r\n\t\t\t} finally {\r\n\t\t\t\tthis.loading = false\r\n\t\t\t}\r\n\t\t},\r\n\t\t// 获取服务器地址\r\n\t\tgetServerUrl() {\r\n\t\t\treturn getServerUrl()\r\n\t\t},\r\n\t\t// 编辑菜品\r\n\t\tedIt(item) {\r\n\t\t\tthis.$router.push({\r\n\t\t\t\tname: 'upload',\r\n\t\t\t\tquery: {\r\n\t\t\t\t\tid: item.id\r\n\t\t\t\t}\r\n\t\t\t})\r\n\t\t},\r\n\t\t// 上架/下架\r\n\t\tasync shelf(id, onsale, index) {\r\n\t\t\ttry {\r\n\t\t\t\tthis.shelfload = index\r\n\t\t\t\tconst res = await requestUtil({\r\n\t\t\t\t\turl: \"/dish/fromsale\",\r\n\t\t\t\t\tmethod: \"post\",\r\n\t\t\t\t\tdata: {\r\n\t\t\t\t\t\tid: id,\r\n\t\t\t\t\t\tonsale: onsale\r\n\t\t\t\t\t}\r\n\t\t\t\t})\r\n\t\t\t\tif(res.code === 0) {\r\n\t\t\t\t\tthis.$message.success(onsale ? '上架成功' : '下架成功')\r\n\t\t\t\t\tthis.getDishList()\r\n\t\t\t\t}\r\n\t\t\t} catch(error) {\r\n\t\t\t\tconsole.error(\"操作失败:\", error)\r\n\t\t\t} finally {\r\n\t\t\t\tthis.shelfload = -1\r\n\t\t\t}\r\n\t\t},\r\n\t\t// 删除菜品\r\n\t\tasync deleteDish(id) {\r\n\t\t\ttry {\r\n\t\t\t\tawait this.$confirm('确认删除该菜品?', '提示', {\r\n\t\t\t\t\tconfirmButtonText: '确定',\r\n\t\t\t\t\tcancelButtonText: '取消',\r\n\t\t\t\t\ttype: 'warning'\r\n\t\t\t\t})\r\n\t\t\t\tconst res = await requestUtil({\r\n\t\t\t\t\turl: \"/dish/delete\",\r\n\t\t\t\t\tmethod: \"post\",\r\n\t\t\t\t\tdata: {\r\n\t\t\t\t\t\tid: id\r\n\t\t\t\t\t}\r\n\t\t\t\t})\r\n\t\t\t\tif(res.code === 0) {\r\n\t\t\t\t\tthis.$message.success('删除成功')\r\n\t\t\t\t\tthis.getDishList()\r\n\t\t\t\t}\r\n\t\t\t} catch(error) {\r\n\t\t\t\tif(error !== 'cancel') {\r\n\t\t\t\t\tconsole.error(\"删除失败:\", error)\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t},\r\n\t\t// 分页\r\n\t\tcurrentchange(page) {\r\n\t\t\tthis.getDishList()\r\n\t\t}\r\n\t},\r\n\tcreated() {\r\n\t\tthis.getDishList()\r\n\t}\r\n}\r\n</script>\r\n\r\n<style>\r\n.tab-list {\r\n\tdisplay: grid;\r\n\tgrid-template-columns: 1fr 1fr 1fr 1fr 1fr 2fr;\r\n\talign-items: center;\r\n\theight: 50px;\r\n\tbackground-color: #f5f5f5;\r\n\tpadding: 0 20px;\r\n}\r\n\r\n.tab-table {\r\n\tdisplay: grid;\r\n\tgrid-template-columns: 1fr 1fr 1fr 1fr 1fr 2fr;\r\n\talign-items: center;\r\n\tpadding: 20px;\r\n\tborder-bottom: 1px solid #eee;\r\n}\r\n\r\n.elimg {\r\n\twidth: 50px;\r\n\theight: 50px;\r\n\tborder-radius: 5px;\r\n}\r\n</style>\r\n"]}]}