}\r\n\t\t},\r\n\t\t// жҺҘеҚ•\r\n\t\tasync receiving(index, id, retryCount = 0) {\r\n\t\t\tconst MAX_RETRIES = 3; // жңҖеӨ§йҮҚиҜ•ж¬Ўж•°\r\n\t\t\tconst RETRY_DELAY = 500; // йҮҚиҜ•е»¶иҝҹпјҢжҜ«з§’\r\n\r\n\t\t\tconsole.log(`[Receiving] Attempt: ${retryCount}, Order ID: ${id}`);\r\n\t\t\tthis.rece_load = index; // и®ҫзҪ®еҠ иҪҪзҠ¶жҖҒ\r\n\t\t\tlet res = null; // зЎ®дҝқresеңЁж•ҙдёӘtry-catch-finallyеқ—дёӯеҸҜи§Ғ\r\n\t\t\tlet finalOutcome = 'pending'; // 'success', 'fail', 'retry'\r\n\t\t\tlet finalErrorMessage = '';\r\n\r\n\t\t\ttry {\r\n\t\t\t\tres = await new this.Request(this.Urls.m().receiving, { id: id, order_receiving: 'rec_order' }).modepost();\r\n\t\t\t\tconsole.log(`[Receiving] Response for attempt ${retryCount}:`, res);\r\n\r\n\t\t\t\tif (res.code === 0) {\r\n\t\t\t\t\tfinalOutcome = 'success';\r\n\t\t\t\t\tthis.$set(this.tabcont[index], 'order_receiving', 'rec_order');\r\n\t\t\t\t} else {\r\n\t\t\t\t\tconsole.log(`[Receiving] Failure for attempt ${retryCount}. Message: ${res.msg}`);\r\n\t\t\t\t\tif (res.msg === \"з”ЁжҲ·жңӘж”Ҝд»ҳпјҢдёҚиғҪжҺҘеҚ•\" && retryCount < MAX_RETRIES) {\r\n\t\t\t\t\t\tfinalOutcome = 'retry';\r\n\t\t\t\t\t\tconsole.log(`[Receiving] Retrying for attempt ${retryCount}...`);\r\n\t\t\t\t\t\tsetTimeout(() => {\r\n\t\t\t\t\t\t\tthis.receiving(index, id, retryCount + 1);\r\n\t\t\t\t\t\t}, RETRY_DELAY);\r\n\t\t\t\t\t\treturn; // з«ӢеҚіиҝ”еӣһпјҢзӯүеҫ…йҮҚиҜ•з»“жһңпјҢдёҚжү§иЎҢеҗҺз»ӯзҡ„finallyеқ—зҡ„жё…зҗҶ\r\n\t\t\t\t\t} else {\r\n\t\t\t\t\t\tfinalOutcome = 'fail';\r\n\t\t\t\t\t\tfinalErrorMessage = res.msg === \"з”ЁжҲ·жңӘж”Ҝд»ҳпјҢдёҚиғҪжҺҘеҚ•\" ?\r\n\t\t\t\t\t\t\t\t\t\t\t 'и®ўеҚ•зҠ¶жҖҒе°ҡжңӘжӣҙж–°пјҢиҜ·зЁҚеҗҺеҲ·ж–°йҮҚиҜ•гҖӮ' :\r\n\t\t\t\t\t\t\t\t\t\t\t res.msg || 'жҺҘеҚ•еӨұиҙҘ';\r\n\t\t\t\t\t\tconsole.log(`[Receiving] Final failure for attempt ${retryCount}. Error: ${finalErrorMessage}`);\r\n\t\t\t\t\t}\r\n\t\t\t\t}\r\n\t\t\t} catch (e) {\r\n\t\t\t\tconsole.error(`[Receiving] Catch block error for attempt ${retryCount}:`, e);\r\n\t\t\t\tfinalOutcome = 'fail';\r\n\t\t\t\tfinalErrorMessage = 'жңҚеҠЎеҷЁеҸ‘з”ҹй”ҷиҜҜ,иҜ·йҮҚиҜ•';\r\n\t\t\t} finally {\r\n\t\t\t\tconsole.log(`[Receiving] Finally block for attempt ${retryCount}. Final outcome: ${finalOutcome}`);\r\n\t\t\t\tif (finalOutcome === 'success') {\r\n\t\t\t\t\t// е»¶иҝҹobtainorderе’Ңжё…йҷӨеҠ иҪҪзҠ¶жҖҒпјҢзЎ®дҝқtoastеҸҜи§Ғ\r\n\t\t\t\t\tsetTimeout(() => {\r\n\t\t\t\t\t\tthis.obtainorder(0);\r\n\t\t\t\t\t\tthis.rece_load = -1;\r\n\t\t\t\t\t}, 100); // е»¶иҝҹ100жҜ«з§’\r\n\t\t\t\t} else if (finalOutcome === 'fail') {\r\n\t\t\t\t\t// е»¶иҝҹobtainorderе’Ңжё…йҷӨеҠ иҪҪзҠ¶жҖҒпјҢзЎ®дҝқtoastеҸҜи§Ғ\r\n\t\t\t\t\tsetTimeout(() => {\r\n\t\t\t\t\t\tthis.obtainorder(0);\r\n\t\t\t\t\t\tthis.rece_load = -1;\r\n\t\t\t\t\t}, 100); // е»¶иҝҹ100жҜ«з§’\r\n\t\t\t\t} else {\r\n\t\t\t\t\t// finalOutcome === 'retry'пјҢдёҚйңҖиҰҒеңЁиҝҷйҮҢеҒҡд»»дҪ•дәӢжғ…пјҢеӣ дёәеҮҪж•°е·Із»Ҹиҝ”еӣһпјҢзӯүеҫ…дёӢдёҖж¬ЎйҮҚиҜ•гҖӮ\r\n\t\t\t\t\t// rece_load дјҡеңЁжңҖз»ҲжҲҗеҠҹжҲ–еӨұиҙҘж—¶иў«жё…йҷӨгҖӮ\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t},\r\n\t\t// ејҖе§ӢиҮӘеҠЁеҲ·ж–°\r\n\t\tstartAutoRefresh() {\r\n\t\t\t// жҜҸ10з§’иҮӘеҠЁеҲ·ж–°дёҖж¬Ў\r\n\t\t\tthis.refreshTimer = setInterval(() => {\r\n\t\t\t\tthis.obtainorder(0)\r\n\t\t\t}, 10000)\r\n\t\t},\r\n\t\t// еҒңжӯўиҮӘеҠЁеҲ·ж–°\r\n\t\tstopAutoRefresh() {\r\n\t\t\tif (this.refreshTimer) {\r\n\t\t\t\tclearInterval(this.refreshTimer)\r\n\t\t\t\tthis.refreshTimer = null\r\n\t\t\t}\r\n\t\t},\r\n\t\t// еҲ·ж–°и®ўеҚ•\r\n\t\trefresh_order(){\r\n\t\t\tthis.loading = true\r\n\t\t\tthis.deta_load = -1,//жҹҘзңӢиҜҰз»ҶиҸңеҚ•\r\n\t\t\tthis.rece_load = -1,//жҺҘеҚ•\r\n\t\t\tthis.check_load = -1,//з»“иҙҰ\r\n\t\t\tthis.obtainorder(1)\r\n\t\t},\r\n\t\t// жҹҘиҜўи®ўеҚ•\r\n\t\tqueryFun(){\r\n\t\t\tthis.pagenum = 0\r\n\t\t\tthis.obtainorder(0)\r\n\t\t},\r\n\t\t// жӣҙж–°жҙҫйҖҒзҠ¶жҖҒ\n\t\tasync updateDeliveryStatus(index, orderId, isDelivered) {\n\t\t\tthis.deliver_load = index\n\t\t\ttry {\n\t\t\t\tlet res = await new this.Request(this.Urls.m().updateDeliveryStatus, { \n\t\t\t\t\torderId: orderId, \n\t\t\t\t\tisDelivered: isDelivered \n\t\t\t\t}).modepost()\n\t\t\t\t\n\t\t\t\tconsole.log('жҙҫйҖҒзҠ¶жҖҒжӣҙж–°е“Қеә”:', res)\n\t\t\t\t\n\t\t\t\tif (res.code === 0) {\n\t\t\t\t\t// е…Ҳжӣҙж–°жң¬ең°зҠ¶жҖҒпјҢжҸҗдҫӣеҚіж—¶еҸҚйҰҲ\n\t\t\t\t\tthis.$set(this.tabcont[index], 'is_delivered', isDelivered)\n\t\t\t\t\tif (isDelivered) {\n\t\t\t\t\t\tthis.$set(this.tabcont[index], 'delivery_time', new Date().toLocaleString())\n\t\t\t\t\t}\n\t\t\t\t\t// е»¶иҝҹеҲ·ж–°и®ўеҚ•еҲ—иЎЁ\n\t\t\t\t\tsetTimeout(() => {\n\t\t\t\t\t\tthis.obtainorder(0)\n\t\t\t\t\t}, 500)\n\t\t\t\t} else {\n\t\t\t\t\t// еҲ·ж–°и®ўеҚ•еҲ—иЎЁ\n\t\t\t\t\tthis.obtainorder(0)\n\t\t\t\t}\n\t\t\t} catch (e) {\n\t\t\t\tconsole.error('жҙҫйҖҒзҠ¶жҖҒжӣҙж–°й”ҷиҜҜ:', e)\n\t\t\t\t// еҲ·ж–°и®ўеҚ•еҲ—иЎЁ\n\t\t\t\tthis.obtainorder(0)\n\t\t\t} finally {\n\t\t\t\t// е»¶иҝҹжё…йҷӨеҠ иҪҪзҠ¶жҖҒпјҢзЎ®дҝқз”ЁжҲ·зңӢеҲ°еҸҚйҰҲ\n\t\t\t\tsetTimeout(() => {\n\t\t\t\t\tthis.deliver_load = -1\n\t\t\t\t}, 500)\n\t\t\t}\n\t\t},\r\n\t\t// жү“ејҖиҜ„д»·з®ЎзҗҶ\n\t\tasync openRatingManagement() {\n\t\t\tthis.ratingDialogVisible = true\n\t\t\tthis.loading = true\n\t\t\ttry {\n\t\t\t\t// жү“еҚ°API URL\n\t\t\t\tconsole.log('иҜ„д»·з®ЎзҗҶAPI URL:', this.Urls.m().getRatingStats)\n\t\t\t\t\n\t\t\t\t// и°ғз”Ёзңҹе®һзҡ„еҗҺз«ҜAPIиҺ·еҸ–иҜ„д»·ж•°жҚ®\n\t\t\t\tlet res = await new this.Request(this.Urls.m().getRatingStats).modeget()\n\t\t\t\t\n\t\t\t\tconsole.log('иҜ„д»·ж•°жҚ®е“Қеә”:', res)\n\t\t\t\t\n\t\t\t\t// axiosиҝ”еӣһзҡ„е“Қеә”дёӯпјҢе®һйҷ…ж•°жҚ®еңЁres.dataдёӯ\n\t\t\t\tconst responseData = res.data\n\t\t\t\tconsole.log('е®һйҷ…иҜ„д»·ж•°жҚ®:', responseData)\n\t\t\t\t\n\t\t\t\tif (responseData && responseData.code === 0) {\n\t\t\t\t\t// зЎ®дҝқdistributionеҜ№иұЎзҡ„й”®жҳҜеӯ—з¬ҰдёІзұ»еһӢ\n\t\t\t\t\tconst formattedDistribution = {}\n\t\t\t\t\tif (responseData.distribution) {\n\t\t\t\t\t\tfor (let key in responseData.distribution) {\n\t\t\t\t\t\t\tformattedDistribution[key.toString()] = responseData.distribution[key]\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t\t\n\t\t\t\t\t// жһ„йҖ жӯЈзЎ®зҡ„ratingStatsеҜ№иұЎ\n\t\t\t\t\tthis.ratingStats = {\n\t\t\t\t\t\ttotalRatings: responseData.totalRatings || 0,\n\t\t\t\t\t\taverageRating: responseData.averageRating || 0,\n\t\t\t\t\t\tmaxRating: responseData.maxRating || 0,\n\t\t\t\t\t\tminRating: responseData.minRating || 0,\n\t\t\t\t\t\tdistribution: formattedDistribution,\n\t\t\t\t\t\tratingList: responseData.ratingList || []\n\t\t\t\t\t}\n\t\t\t\t\t\n\t\t\t\t\tthis.ratingList = responseData.ratingList || []\n\t\t\t\t\t// еҲқе§ӢеҢ–иҝҮж»ӨеҗҺзҡ„еҲ—иЎЁ\n\t\t\t\t\tthis.filteredRatingList = [...this.ratingList]\n\t\t\t\t\tconsole.log('еӨ„зҗҶеҗҺзҡ„ж•°жҚ®:', this.ratingStats, this.ratingList, this.filteredRatingList)\n\t\t\t\t} else {\n\t\t\t\t\tconsole.error('иҺ·еҸ–иҜ„д»·ж•°жҚ®еӨұиҙҘ:', responseData)\n\t\t\t\t\tnew this.mytitle(this.$message,'error',responseData && responseData.msg || 'иҺ·еҸ–иҜ„д»·ж•°жҚ®еӨұиҙҘ').funtitle()\n\t\t\t\t}\n\t\t\t} catch (e) {\n\t\t\t\tconsole.error('иҺ·еҸ–иҜ„д»·ж•°жҚ®й”ҷиҜҜ:', e)\n\t\t\t\tnew this.mytitle(this.$message,'error','иҺ·еҸ–иҜ„д»·ж•°жҚ®еӨұиҙҘ').funtitle()\n\t\t\t} finally {\n\t\t\t\tthis.loading = false\n\t\t\t}\n\t\t},\n\t\t// жҗңзҙўиҜ„еҲҶ\n\t\tsearchRating() {\n\t\t\tif (this.selectedRating) {\n\t\t\t\tthis.filteredRatingList = this.ratingList.filter(item => item.rating == this.selectedRating)\n\t\t\t} else {\n\t\t\t\tthis.filteredRatingList = [...this.ratingList]\n\t\t\t}\n\t\t}\r\n\t},\r\n\tcreated() {\r\n\t\t// иҺ·еҸ–и®ўеҚ•\r\n\t\tthis.obtainorder(0)\r\n\t\t// и®ўеҚ•жҸҗйҶ’\r\n\t\tthis.dingdan = localStorage.getItem(\"order_num\")\r\n\t\t// еҗҜеҠЁиҮӘеҠЁеҲ·ж–°\r\n\t\tthis.startAutoRefresh()\r\n\t},\r\n\tbeforeDestroy() {\r\n\t\t// з»„д»¶й”ҖжҜҒеүҚеҒңжӯўиҮӘеҠЁеҲ·ж–°\r\n\t\tthis.stopAutoRefresh()\r\n\t},\r\n\twatch: {\r\n\t\t// зӣ‘еҗ¬и®ўеҚ•жҸҗйҶ’\r\n\t\t\"$store.state.remind\"(newValue, oldValue) {\r\n\t\t\tthis.dingdan = newValue.num\r\n\t\t}\r\n\t},\r\n}\r\n",{"version":3,"sources":["order.vue"],"names":[],"mappings":";AA6LA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;;AAEA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"order.vue","sourceRoot":"src/page/order","sourcesContent":["<template>\n\t<div class=\"ordering\" v-loading.fullscreen.lock=\"loading\">\n\t\t<div class=\"heading\">и®ўеҚ•з®ЎзҗҶ</div>\n\t\t<div class=\"content-view\">\n\t\t\t<!-- жҹҘиҜў -->\n\t\t\t<div class=\"query-view\">\n\t\t\t\t<!-- и®ўеҚ•еҸ·жҹҘиҜў -->\n\t\t\t\t<div class=\"quotation-query\">\n\t\t\t\t\t<div>и®ўеҚ•еҸ·</div>\n\t\t\t\t\t<div>\n\t\t\t\t\t\t<el-input v-model=\"statevalue\" placeholder=\"иҜ·иҫ“е…Ҙи®ўеҚ•еҸ·\"></el-input>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<!-- жҢүй’® -->\n\t\t\t\t<div class=\"quotation-query\"><el-button type=\"success\" size=\"medium\" @click=\"queryFun()\">жҹҘиҜў</el-button></div>\n\t\t\t</div>\n\t\t\t<div class=\"button-view\">\n\n\t\t\t  <el-button type=\"warning\" size=\"small\" @click=\"refresh_order()\">еҲ·ж–°и®ўеҚ•</el-button>\n\t\t\t  <el-button type=\"primary\" size=\"small\" @click=\"openRatingManagement()\">иҜ„д»·з®ЎзҗҶ</el-button>\n\n\t\t\t</div>\r\n\t\t\t<!-- жҳҜеҗҰжңүж•°жҚ® -->\r\n\t\t\t<div v-if=\"nodatas\">\r\n\t\t\t\t<!-- иЎЁеӨҙ -->\r\n\t\t\t\t<div class=\"tab-list\">\r\n\t\t\t\t\t<span v-for=\"(item,index) in tablist\" :key=\"index\">{{item}}</span>\r\n\t\t\t\t</div>\r\n\t\t\t\t<!-- иЎЁж ј -->\r\n\t\t\t\t<div class=\"tab-table-quo\" v-for=\"(item,index) in tabcont\" :key=\"index\">\r\n\t\t\t\t\t<div>{{item.order_no}}</div>\r\n\t\t\t\t\t<div>{{item.table_number}}</div>\r\n\t\t\t\t\t<div class=\"remarks-text\">\r\n\t\t\t\t\t\t<el-button type=\"small\" :loading=\"index == deta_load ? true : false\" @click=\"detailed_menu(index,item)\">иҜҰз»ҶиҸңеҚ•</el-button>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t<div>{{Price(item.sett_amount)}}</div>\r\n\t\t\t\t\t<div>\r\n\t\t\t\t\t\t<el-button type=\"info\" size=\"small\" v-if=\"item.order_receiving == 'mis_orders'\" :loading=\"index == rece_load ? true : false\" @click=\"receiving(index,item.id)\">еҫ…жҺҘеҚ•</el-button>\r\n\t\t\t\t\t\t<el-button size=\"small\" type=\"success\" v-if=\"item.order_receiving == 'rec_order'\">е·ІжҺҘеҚ•</el-button>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t<div>\r\n\t\t\t\t\t\t<el-button size=\"small\" type=\"success\" disabled v-if=\"item.transac_status == 'success'\">з”ЁжҲ·е·Іж”Ҝд»ҳ</el-button>\r\n\t\t\t\t\t\t<el-button size=\"small\" type=\"warning\" disabled v-if=\"item.transac_status == 'unsettled'\">з”ЁжҲ·жңӘд»ҳж¬ҫ</el-button>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t<div>\r\n\t\t\t\t\t\t<el-button type=\"primary\" size=\"small\" v-if=\"!item.is_delivered\" @click=\"updateDeliveryStatus(index, item.id, true)\">жҙҫйҖҒ</el-button>\r\n\t\t\t\t\t\t<el-button type=\"success\" size=\"small\" disabled v-else>е·ІжҙҫйҖҒ</el-button>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<!-- еҲҶйЎө -->\r\n\t\t\t\t<el-pagination\r\n\t\t\t\t  background\r\n\t\t\t\t  layout=\"prev, pager, next\"\r\n\t\t\t\t  :hide-on-single-page=\"true\"\r\n\t\t\t\t  :total=\"total\"\r\n\t\t\t\t  @current-change=\"currentchange\"\r\n\t\t\t\t  >\r\n\t\t\t\t</el-pagination>\r\n\t\t\t</div>\r\n\t\t\t<!-- жІЎжңүж•°жҚ® -->\r\n\t\t\t<div class=\"nodatas\" v-if=\"!nodatas\">{{nodvalue}}</div>\r\n\t\t\t<!-- и®ўеҚ•иҜҰз»Ҷеј№зӘ— -->\r\n\t\t\t<el-dialog\r\n\t\t\t  title=\"и®ўеҚ•иҜҰжғ…\"\r\n\t\t\t  :visible.sync=\"dialogVisible\"\r\n\t\t\t  width=\"600px\"\r\n\t\t\t  :center=\"true\"\r\n\t\t\t  >\r\n\t\t\t  <div class=\"order-detail-info\">\r\n\t\t\t\t  <div class=\"info-item\">\r\n\t\t\t\t\t  <span class=\"label\">и®ўеҚ•зј–еҸ·пјҡ</span>\r\n\t\t\t\t\t  <span class=\"value\">{{currentOrder.order_no}}</span>\r\n\t\t\t\t  </div>\r\n\t\t\t\t  <div class=\"info-item\">\r\n\t\t\t\t\t  <span class=\"label\">з”ЁйӨҗдәәж•°пјҡ</span>\r\n\t\t\t\t\t  <span class=\"value\">{{currentOrder.number_of_diners || '-'}}дәә</span>\r\n\t\t\t\t  </div>\r\n\t\t\t\t  <div class=\"info-item\">\r\n\t\t\t\t\t  <span class=\"label\">дёӢеҚ•ж—¶й—ҙпјҡ</span>\r\n\t\t\t\t\t  <span class=\"value\">{{currentOrder.order_time}}</span>\r\n\t\t\t\t  </div>\r\n\t\t\t\t  <div class=\"info-item\">\r\n\t\t\t\t\t  <span class=\"label\">ж”Ҝд»ҳж—¶й—ҙпјҡ</span>\r\n\t\t\t\t\t  <span class=\"value\">{{currentOrder.pay_time || '-'}}</span>\r\n\t\t\t\t  </div>\r\n\t\t\t\t  <div class=\"info-item\">\r\n\t\t\t\t\t  <span class=\"label\">ж”Ҝд»ҳдәӨжҳ“еҸ·пјҡ</span>\r\n\t\t\t\t\t  <div style=\"flex: 1; text-align: left !important;\">{{currentOrder.transaction_id || '-'}}</div>\r\n\t\t\t\t  </div>\r\n\t\t\t\t  <div class=\"info-item\">\r\n\t\t\t\t\t  <span class=\"label\">жЎҢеҸ·пјҡ</span>\r\n\t\t\t\t\t  <span class=\"value\">{{currentOrder.table_number}}</span>\r\n\t\t\t\t  </div>\r\n\t\t\t\t  <div class=\"info-item\">\r\n\t\t\t\t\t  <span class=\"label\">жҙҫйҖҒзҠ¶жҖҒпјҡ</span>\r\n\t\t\t\t\t  <span class=\"value\">{{currentOrder.is_delivered ? 'е·ІжҙҫйҖҒ' : 'жңӘжҙҫйҖҒ'}}</span>\r\n\t\t\t\t  </div>\r\n\t\t\t\t  <div class=\"info-item\">\r\n\t\t\t\t\t  <span class=\"label\">жҙҫйҖҒж—¶й—ҙпјҡ</span>\r\n\t\t\t\t\t  <span class=\"value\">{{currentOrder.delivery_time || '-'}}</span>\r\n\t\t\t\t  </div>\r\n\t\t\t\t  <div class=\"info-item\">\r\n\t\t\t\t\t  <span class=\"label\">з”ЁйӨҗиҜ„еҲҶпјҡ</span>\r\n\t\t\t\t\t  <span class=\"value\">{{currentOrder.rating ? currentOrder.rating + 'еҲҶ' : '-'}}</span>\r\n\t\t\t\t  </div>\r\n\t\t\t\t  <div class=\"info-item\">\n\t\t\t\t\t\t<span class=\"label\">иҜ„д»·ж—¶й—ҙпјҡ</span>\n\t\t\t\t\t\t<span class=\"value\">{{currentOrder.comment_time || '-'}}</span>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"info-item\">\n\t\t\t\t\t\t<span class=\"label\">иҜ„д»·еҶ…е®№пјҡ</span>\n\t\t\t\t\t\t<span class=\"value\">{{currentOrder.comment || '-'}}</span>\n\t\t\t\t\t</div>\r\n\t\t\t  </div>\r\n\t\t\t  <div class=\"menu-title\">иҸңе“Ғжё…еҚ•</div>\r\n\t\t\t  <div class=\"menu-list\">\r\n\t\t\t\t  <div class=\"menu-item\" v-for=\"(item,index) in user_menu\" :key=\"index\">\r\n\t\t\t\t\t  <div class=\"menu-detail\">\r\n\t\t\t\t\t\t  <span class=\"dish-name\">{{item.name}}</span>\r\n\t\t\t\t\t\t  <span class=\"dish-quantity\">{{item.quantity}}{{item.unit}}</span>\r\n\t\t\t\t\t  </div>\r\n\t\t\t\t  </div>\r\n\t\t\t  </div>\r\n\t\t\t</el-dialog>\r\n\t\t\t\r\n\t\t\t<!-- иҜ„д»·з®ЎзҗҶеј№зӘ— -->\r\n\t\t\t<el-dialog\r\n\t\t\t  title=\"иҜ„д»·з®ЎзҗҶ\"\r\n\t\t\t  :visible.sync=\"ratingDialogVisible\"\r\n\t\t\t  width=\"800px\"\r\n\t\t\t  :center=\"true\"\r\n\t\t\t  >\r\n\t\t\t  <div class=\"rating-management\">\r\n\t\t\t\t  <div class=\"rating-stats\">\r\n\t\t\t\t\t  <h3>иҜ„д»·з»ҹи®Ў</h3>\r\n\t\t\t\t\t  <div class=\"stats-grid\">\r\n\t\t\t\t\t\t  <div class=\"stat-item\">\r\n\t\t\t\t\t\t\t  <div class=\"stat-label\">жҖ»иҜ„д»·ж•°</div>\r\n\t\t\t\t\t\t\t  <div class=\"stat-value\">{{ratingStats.totalRatings}}</div>\r\n\t\t\t\t\t\t  </div>\r\n\t\t\t\t\t\t  <div class=\"stat-item\">\r\n\t\t\t\t\t\t\t  <div class=\"stat-label\">е№іеқҮиҜ„еҲҶ</div>\r\n\t\t\t\t\t\t\t  <div class=\"stat-value\">{{ratingStats.averageRating.toFixed(1)}}еҲҶ</div>\r\n\t\t\t\t\t\t  </div>\r\n\t\t\t\t\t\t  <div class=\"stat-item\">\r\n\t\t\t\t\t\t\t  <div class=\"stat-label\">жңҖй«ҳеҲҶ</div>\r\n\t\t\t\t\t\t\t  <div class=\"stat-value\">{{ratingStats.maxRating}}еҲҶ</div>\r\n\t\t\t\t\t\t  </div>\r\n\t\t\t\t\t\t  <div class=\"stat-item\">\r\n\t\t\t\t\t\t\t  <div class=\"stat-label\">жңҖдҪҺеҲҶ</div>\r\n\t\t\t\t\t\t\t  <div class=\"stat-value\">{{ratingStats.minRating}}еҲҶ</div>\r\n\t\t\t\t\t\t  </div>\r\n\t\t\t\t\t  </div>\r\n\t\t\t\t  </div>\r\n\t\t\t\t  <div class=\"rating-distribution\">\r\n\t\t\t\t\t  <h3>иҜ„еҲҶеҲҶеёғ</h3>\r\n\t\t\t\t\t  <div class=\"distribution-bar\">\r\n\t\t\t\t\t\t  <div v-for=\"(count, score) in ratingStats.distribution\" :key=\"score\" class=\"bar-item\">\r\n\t\t\t\t\t\t\t  <div class=\"bar-label\">{{score}}еҲҶ</div>\r\n\t\t\t\t\t\t\t  <div class=\"bar-container\">\r\n\t\t\t\t\t\t\t\t  <div class=\"bar-fill\" :style=\"{ width: (count / ratingStats.totalRatings * 100) + '%' }\"></div>\r\n\t\t\t\t\t\t\t  </div>\r\n\t\t\t\t\t\t\t  <div class=\"bar-count\">{{count}}</div>\r\n\t\t\t\t\t\t  </div>\r\n\t\t\t\t\t  </div>\r\n\t\t\t\t  </div>\r\n\t\t\t\t  <div class=\"rating-list\">\r\n\t\t\t\t\t  <h3>иҜ„д»·иҜҰжғ…</h3>\r\n\t\t\t\t\t  <div class=\"rating-search\">\r\n\t\t\t\t\t\t  <el-select v-model=\"selectedRating\" placeholder=\"жҢүиҜ„еҲҶзӯүзә§жҗңзҙў\">\r\n\t\t\t\t\t\t\t  <el-option label=\"е…ЁйғЁ\" value=\"\"></el-option>\r\n\t\t\t\t\t\t\t  <el-option v-for=\"score in 10\" :key=\"score\" :label=\"score + 'еҲҶ'\" :value=\"score\"></el-option>\r\n\t\t\t\t\t\t  </el-select>\r\n\t\t\t\t\t\t  <el-button type=\"primary\" size=\"small\" @click=\"searchRating()\">жҗңзҙў</el-button>\r\n\t\t\t\t\t  </div>\r\n\t\t\t\t\t  <el-table :data=\"filteredRatingList\" style=\"width: 100%\">\r\n\t\t\t\t\t\t  <el-table-column prop=\"order_no\" label=\"и®ўеҚ•еҸ·\" width=\"180\"></el-table-column>\r\n\t\t\t\t\t\t  <el-table-column prop=\"comment_time\" label=\"иҜ„д»·ж—¶й—ҙ\"></el-table-column>\r\n\t\t\t\t\t\t  <el-table-column prop=\"rating\" label=\"иҜ„д»·зӯүзә§\"></el-table-column>\r\n\t\t\t\t\t  </el-table>\r\n\t\t\t\t  </div>\r\n\t\t\t  </div>\r\n\t\t\t</el-dialog>\r\n\t\t</div>\r\n\t\t<div style=\"height: 120px;\"></div>\r\n\t</div>\r\n</template>\r\n\r\n<script>\r\n// дәӨжҳ“зҠ¶жҖҒ\r\nimport {staff} from '../../../config/state-type.js'\r\n// д»·ж јиЎҘйўҶ\r\nconst Price = require('e-commerce_price') // йҮҚж–°еҜје…Ҙ Price еҮҪж•°\r\nexport default{\r\n\tdata() {\n\t\t\treturn {\n\t\t\t\tPrice:Price, // жҒўеӨҚ Price ж•°жҚ®еұһжҖ§\n\t\t\t\toptions:staff(),\n\t\t\t\tloading: true,\n\t\t\t\tnodatas:true,\n\t\t\t\tdialogVisible:false,//еј№еҮәиҜҰз»ҶиҸңеҚ•\n\t\t\t\tratingDialogVisible:false,//иҜ„д»·з®ЎзҗҶеј№зӘ—\n\t\t\t\tdeta_load:-1,//жҹҘзңӢиҜҰз»ҶиҸңеҚ•\n\t\t\t\trece_load:-1,//жҺҘеҚ•\n\t\t\t\tcheck_load:-1,//з»“иҙҰ\n\t\t\t\tdeliver_load:-1,//жҙҫйҖҒ\n\t\t\t\ttime:'',//дәӨжҳ“ж—¶й—ҙ\n\t\t\t\tstatevalue:'',//дәӨжҳ“зҠ¶жҖҒ\n\t\t\t\tnodvalue:'жІЎжңүи®ўеҚ•ж•°жҚ®',\n\t\t\t\ttotal:0,//жҖ»жқЎж•°\n\t\t\t\tpagenum:0,\n\t\t\t\tpickerOptions: {\n\t\t\t\t    disabledDate(time) {return time.getTime() > Date.now();}\n\t\t\t\t},\n\t\t\t\ttablist:['и®ўеҚ•еҸ·','жЎҢеҸ·','иҸңеҚ•иҜҰжғ…','дәӨжҳ“йҮ‘йўқ(е…ғ)','жҺҘеҚ•зҠ¶жҖҒ','дәӨжҳ“зҠ¶жҖҒ','жңәеҷЁдәәжҙҫйҖҒ'],\n\t\t\t\ttabcont:[],\n\t\t\t\tuser_menu:[],//з”ЁжҲ·иҜҰз»ҶиҸңеҚ•\n\t\t\t\tcurrentOrder: {}, // еҪ“еүҚжҹҘзңӢзҡ„и®ўеҚ•дҝЎжҒҜ\n\t\t\t\tdingdan:0,//и®ўеҚ•жҸҗйҶ’\n\t\t\t\trefreshTimer: null, // ж·»еҠ е®ҡж—¶еҷЁеҸҳйҮҸ\n\t\t\t\tratingStats: {\n\t\t\t\t\ttotalRatings: 0,\n\t\t\t\t\taverageRating: 0,\n\t\t\t\t\tmaxRating: 0,\n\t\t\t\t\tminRating: 0,\n\t\t\t\t\tdistribution: {} // иҜ„еҲҶеҲҶеёғпјҢkeyдёәеҲҶж•°пјҢvalueдёәж•°йҮҸ\n\t\t\t\t},\n\t\t\t\tratingList: [], // иҜ„д»·иҜҰжғ…еҲ—иЎЁ\n\t\t\t\tselectedRating: '', // йҖүдёӯзҡ„иҜ„еҲҶзӯүзә§\n\t\t\t\tfilteredRatingList: [] // иҝҮж»ӨеҗҺзҡ„иҜ„д»·еҲ—иЎЁ\n\t\t\t}\r\n\t},\r\n\tmethods:{\r\n\t\t// еҲҶйЎө\r\n\t\tcurrentchange(e){\r\n\t\t\tthis.pagenum = e - 1\r\n\t\t\tthis.obtainorder(0)\r\n\t\t},\r\n\t\t// иҺ·еҸ–и®ўеҚ•\r\n\t\tasync obtainorder(vle){\r\n\t\t\ttry{\r\n\t\t\t\tlet res = await new this.Request(this.Urls.m().obtainorder,{\"pageNum\":this.pagenum+1,\"query\":this.statevalue}).modepost()\r\n\t\t\t\tconsole.log('еҗҺз«Ҝиҝ”еӣһзҡ„и®ўеҚ•ж•°жҚ®:', res.data)\r\n\t\t\t\tthis.nodatas = res.data.total == 0  ? false : true\r\n\t\t\t\tthis.tabcont = res.data.orderList\r\n\t\t\t\tthis.total = res.data.total\r\n\t\t\t\tthis.loading = false\r\n\t\t\t\tif(vle == 1){\r\n\t\t\t\t\tlocalStorage.setItem('order_num',0)\r\n\t\t\t\t\tthis.$store.commit('order_remind',0)\r\n\t\t\t\t}\r\n\t\t\t}catch(e){\r\n\t\t\t\tnew this.mytitle(this.$message,'error','жңҚеҠЎеҷЁеҸ‘з”ҹй”ҷиҜҜ,иҜ·йҮҚиҜ•').funtitle()\r\n\t\t\t}\r\n\t\t},\r\n\t\t// жҹҘзңӢиҜҰз»ҶиҸңеҚ•\r\n\t\tasync detailed_menu(index, order){\r\n\t\t\tthis.deta_load = index\r\n\t\t\tconsole.log('orderеҜ№иұЎ', order); // и°ғиҜ•з”ЁпјҢжҹҘзңӢз”ЁйӨҗдәәж•°еӯ—ж®ө\r\n\t\t\ttry{\r\n\t\t\t\tlet res = await new this.Request(this.Urls.m().vieworder + '?id=' + order.id).modeget()\r\n\t\t\t\tconsole.log(res)\r\n\t\t\t\tthis.user_menu = res.data.list\r\n\t\t\t\tthis.currentOrder = order // дҝқеӯҳеҪ“еүҚи®ўеҚ•дҝЎжҒҜ\r\n\t\t\t\tthis.deta_load = -1\r\n\t\t\t\tthis.dialogVisible = true\r\n\t\t\t}catch(e){\r\n\t\t\t\tthis.deta_load = -1\r\n\t\t\t\tnew this.mytitle(this.$message,'error','жңҚеҠЎеҷЁеҸ‘з”ҹй”ҷиҜҜ,иҜ·йҮҚиҜ•').funtitle()\r\n\t\t\t}\r\n\t\t},\r\n\t\t// жҺҘеҚ•\r\n\t\tasync receiving(index, id, retryCount = 0) {\r\n\t\t\tconst MAX_RETRIES = 3; // жңҖеӨ§йҮҚиҜ•ж¬Ўж•°\r\n\t\t\tconst RETRY_DELAY = 500; // йҮҚиҜ•е»¶иҝҹпјҢжҜ«з§’\r\n\r\n\t\t\tconsole.log(`[Receiving] Attempt: ${retryCount}, Order ID: ${id}`);\r\n\t\t\tthis.rece_load = index; // и®ҫзҪ®еҠ иҪҪзҠ¶жҖҒ\r\n\t\t\tlet res = null; // зЎ®дҝқresеңЁж•ҙдёӘtry-catch-finallyеқ—дёӯеҸҜи§Ғ\r\n\t\t\tlet finalOutcome = 'pending'; // 'success', 'fail', 'retry'\r\n\t\t\tlet finalErrorMessage = '';\r\n\r\n\t\t\ttry {\r\n\t\t\t\tres = await new this.Request(this.Urls.m().receiving, { id: id, order_receiving: 'rec_order' }).modepost();\r\n\t\t\t\tconsole.log(`[Receiving] Response for attempt ${retryCount}:`, res);\r\n\r\n\t\t\t\tif (res.code === 0) {\r\n\t\t\t\t\tfinalOutcome = 'success';\r\n\t\t\t\t\tthis.$set(this.tabcont[index], 'order_receiving', 'rec_order');\r\n\t\t\t\t} else {\r\n\t\t\t\t\tconsole.log(`[Receiving] Failure for attempt ${retryCount}. Message: ${res.msg}`);\r\n\t\t\t\t\tif (res.msg === \"з”ЁжҲ·жңӘж”Ҝд»ҳпјҢдёҚиғҪжҺҘеҚ•\" && retryCount < MAX_RETRIES) {\r\n\t\t\t\t\t\tfinalOutcome = 'retry';\r\n\t\t\t\t\t\tconsole.log(`[Receiving] Retrying for attempt ${retryCount}...`);\r\n\t\t\t\t\t\tsetTimeout(() => {\r\n\t\t\t\t\t\t\tthis.receiving(index, id, retryCount + 1);\r\n\t\t\t\t\t\t}, RETRY_DELAY);\r\n\t\t\t\t\t\treturn; // з«ӢеҚіиҝ”еӣһпјҢзӯүеҫ…йҮҚиҜ•з»“жһңпјҢдёҚжү§иЎҢеҗҺз»ӯзҡ„finallyеқ—зҡ„жё…зҗҶ\r\n\t\t\t\t\t} else {\r\n\t\t\t\t\t\tfinalOutcome = 'fail';\r\n\t\t\t\t\t\tfinalErrorMessage = res.msg === \"з”ЁжҲ·жңӘж”Ҝд»ҳпјҢдёҚиғҪжҺҘеҚ•\" ?\r\n\t\t\t\t\t\t\t\t\t\t\t 'и®ўеҚ•зҠ¶жҖҒе°ҡжңӘжӣҙж–°пјҢиҜ·зЁҚеҗҺеҲ·ж–°йҮҚиҜ•гҖӮ' :\r\n\t\t\t\t\t\t\t\t\t\t\t res.msg || 'жҺҘеҚ•еӨұиҙҘ';\r\n\t\t\t\t\t\tconsole.log(`[Receiving] Final failure for attempt ${retryCount}. Error: ${finalErrorMessage}`);\r\n\t\t\t\t\t}\r\n\t\t\t\t}\r\n\t\t\t} catch (e) {\r\n\t\t\t\tconsole.error(`[Receiving] Catch block error for attempt ${retryCount}:`, e);\r\n\t\t\t\tfinalOutcome = 'fail';\r\n\t\t\t\tfinalErrorMessage = 'жңҚеҠЎеҷЁеҸ‘з”ҹй”ҷиҜҜ,иҜ·йҮҚиҜ•';\r\n\t\t\t} finally {\r\n\t\t\t\tconsole.log(`[Receiving] Finally block for attempt ${retryCount}. Final outcome: ${finalOutcome}`);\r\n\t\t\t\tif (finalOutcome === 'success') {\r\n\t\t\t\t\t// е»¶иҝҹobtainorderе’Ңжё…йҷӨеҠ иҪҪзҠ¶жҖҒпјҢзЎ®дҝқtoastеҸҜи§Ғ\r\n\t\t\t\t\tsetTimeout(() => {\r\n\t\t\t\t\t\tthis.obtainorder(0);\r\n\t\t\t\t\t\tthis.rece_load = -1;\r\n\t\t\t\t\t}, 100); // е»¶иҝҹ100жҜ«з§’\r\n\t\t\t\t} else if (finalOutcome === 'fail') {\r\n\t\t\t\t\t// е»¶иҝҹobtainorderе’Ңжё…йҷӨеҠ иҪҪзҠ¶жҖҒпјҢзЎ®дҝқtoastеҸҜи§Ғ\r\n\t\t\t\t\tsetTimeout(() => {\r\n\t\t\t\t\t\tthis.obtainorder(0);\r\n\t\t\t\t\t\tthis.rece_load = -1;\r\n\t\t\t\t\t}, 100); // е»¶иҝҹ100жҜ«з§’\r\n\t\t\t\t} else {\r\n\t\t\t\t\t// finalOutcome === 'retry'пјҢдёҚйңҖиҰҒеңЁиҝҷйҮҢеҒҡд»»дҪ•дәӢжғ…пјҢеӣ дёәеҮҪж•°е·Із»Ҹиҝ”еӣһпјҢзӯүеҫ…дёӢдёҖж¬ЎйҮҚиҜ•гҖӮ\r\n\t\t\t\t\t// rece_load дјҡеңЁжңҖз»ҲжҲҗеҠҹжҲ–еӨұиҙҘж—¶иў«жё…йҷӨгҖӮ\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t},\r\n\t\t// ејҖе§ӢиҮӘеҠЁеҲ·ж–°\r\n\t\tstartAutoRefresh() {\r\n\t\t\t// жҜҸ10з§’иҮӘеҠЁеҲ·ж–°дёҖж¬Ў\r\n\t\t\tthis.refreshTimer = setInterval(() => {\r\n\t\t\t\tthis.obtainorder(0)\r\n\t\t\t}, 10000)\r\n\t\t},\r\n\t\t// еҒңжӯўиҮӘеҠЁеҲ·ж–°\r\n\t\tstopAutoRefresh() {\r\n\t\t\tif (this.refreshTimer) {\r\n\t\t\t\tclearInterval(this.refreshTimer)\r\n\t\t\t\tthis.refreshTimer = null\r\n\t\t\t}\r\n\t\t},\r\n\t\t// еҲ·ж–°и®ўеҚ•\r\n\t\trefresh_order(){\r\n\t\t\tthis.loading = true\r\n\t\t\tthis.deta_load = -1,//жҹҘзңӢиҜҰз»ҶиҸңеҚ•\r\n\t\t\tthis.rece_load = -1,//жҺҘеҚ•\r\n\t\t\tthis.check_load = -1,//з»“иҙҰ\r\n\t\t\tthis.obtainorder(1)\r\n\t\t},\r\n\t\t// жҹҘиҜўи®ўеҚ•\r\n\t\tqueryFun(){\r\n\t\t\tthis.pagenum = 0\r\n\t\t\tthis.obtainorder(0)\r\n\t\t},\r\n\t\t// жӣҙж–°жҙҫйҖҒзҠ¶жҖҒ\n\t\tasync updateDeliveryStatus(index, orderId, isDelivered) {\n\t\t\tthis.deliver_load = index\n\t\t\ttry {\n\t\t\t\tlet res = await new this.Request(this.Urls.m().updateDeliveryStatus, { \n\t\t\t\t\torderId: orderId, \n\t\t\t\t\tisDelivered: isDelivered \n\t\t\t\t}).modepost()\n\t\t\t\t\n\t\t\t\tconsole.log('жҙҫйҖҒзҠ¶жҖҒжӣҙж–°е“Қеә”:', res)\n\t\t\t\t\n\t\t\t\tif (res.code === 0) {\n\t\t\t\t\t// е…Ҳжӣҙж–°жң¬ең°зҠ¶жҖҒпјҢжҸҗдҫӣеҚіж—¶еҸҚйҰҲ\n\t\t\t\t\tthis.$set(this.tabcont[index], 'is_delivered', isDelivered)\n\t\t\t\t\tif (isDelivered) {\n\t\t\t\t\t\tthis.$set(this.tabcont[index], 'delivery_time', new Date().toLocaleString())\n\t\t\t\t\t}\n\t\t\t\t\t// е»¶иҝҹеҲ·ж–°и®ўеҚ•еҲ—иЎЁ\n\t\t\t\t\tsetTimeout(() => {\n\t\t\t\t\t\tthis.obtainorder(0)\n\t\t\t\t\t}, 500)\n\t\t\t\t} else {\n\t\t\t\t\t// еҲ·ж–°и®ўеҚ•еҲ—иЎЁ\n\t\t\t\t\tthis.obtainorder(0)\n\t\t\t\t}\n\t\t\t} catch (e) {\n\t\t\t\tconsole.error('жҙҫйҖҒзҠ¶жҖҒжӣҙж–°й”ҷиҜҜ:', e)\n\t\t\t\t// еҲ·ж–°и®ўеҚ•еҲ—иЎЁ\n\t\t\t\tthis.obtainorder(0)\n\t\t\t} finally {\n\t\t\t\t// е»¶иҝҹжё…йҷӨеҠ иҪҪзҠ¶жҖҒпјҢзЎ®дҝқз”ЁжҲ·зңӢеҲ°еҸҚйҰҲ\n\t\t\t\tsetTimeout(() => {\n\t\t\t\t\tthis.deliver_load = -1\n\t\t\t\t}, 500)\n\t\t\t}\n\t\t},\r\n\t\t// жү“ејҖиҜ„д»·з®ЎзҗҶ\n\t\tasync openRatingManagement() {\n\t\t\tthis.ratingDialogVisible = true\n\t\t\tthis.loading = true\n\t\t\ttry {\n\t\t\t\t// жү“еҚ°API URL\n\t\t\t\tconsole.log('иҜ„д»·з®ЎзҗҶAPI URL:', this.Urls.m().getRatingStats)\n\t\t\t\t\n\t\t\t\t// и°ғз”Ёзңҹе®һзҡ„еҗҺз«ҜAPIиҺ·еҸ–иҜ„д»·ж•°жҚ®\n\t\t\t\tlet res = await new this.Request(this.Urls.m().getRatingStats).modeget()\n\t\t\t\t\n\t\t\t\tconsole.log('иҜ„д»·ж•°жҚ®е“Қеә”:', res)\n\t\t\t\t\n\t\t\t\t// axiosиҝ”еӣһзҡ„е“Қеә”дёӯпјҢе®һйҷ…ж•°жҚ®еңЁres.dataдёӯ\n\t\t\t\tconst responseData = res.data\n\t\t\t\tconsole.log('е®һйҷ…иҜ„д»·ж•°жҚ®:', responseData)\n\t\t\t\t\n\t\t\t\tif (responseData && responseData.code === 0) {\n\t\t\t\t\t// зЎ®дҝқdistributionеҜ№иұЎзҡ„й”®жҳҜеӯ—з¬ҰдёІзұ»еһӢ\n\t\t\t\t\tconst formattedDistribution = {}\n\t\t\t\t\tif (responseData.distribution) {\n\t\t\t\t\t\tfor (let key in responseData.distribution) {\n\t\t\t\t\t\t\tformattedDistribution[key.toString()] = responseData.distribution[key]\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t\t\n\t\t\t\t\t// жһ„йҖ жӯЈзЎ®зҡ„ratingStatsеҜ№иұЎ\n\t\t\t\t\tthis.ratingStats = {\n\t\t\t\t\t\ttotalRatings: responseData.totalRatings || 0,\n\t\t\t\t\t\taverageRating: responseData.averageRating || 0,\n\t\t\t\t\t\tmaxRating: responseData.maxRating || 0,\n\t\t\t\t\t\tminRating: responseData.minRating || 0,\n\t\t\t\t\t\tdistribution: formattedDistribution,\n\t\t\t\t\t\tratingList: responseData.ratingList || []\n\t\t\t\t\t}\n\t\t\t\t\t\n\t\t\t\t\tthis.ratingList = responseData.ratingList || []\n\t\t\t\t\t// еҲқе§ӢеҢ–иҝҮж»ӨеҗҺзҡ„еҲ—иЎЁ\n\t\t\t\t\tthis.filteredRatingList = [...this.ratingList]\n\t\t\t\t\tconsole.log('еӨ„зҗҶеҗҺзҡ„ж•°жҚ®:', this.ratingStats, this.ratingList, this.filteredRatingList)\n\t\t\t\t} else {\n\t\t\t\t\tconsole.error('иҺ·еҸ–иҜ„д»·ж•°жҚ®еӨұиҙҘ:', responseData)\n\t\t\t\t\tnew this.mytitle(this.$message,'error',responseData && responseData.msg || 'иҺ·еҸ–иҜ„д»·ж•°жҚ®еӨұиҙҘ').funtitle()\n\t\t\t\t}\n\t\t\t} catch (e) {\n\t\t\t\tconsole.error('иҺ·еҸ–иҜ„д»·ж•°жҚ®й”ҷиҜҜ:', e)\n\t\t\t\tnew this.mytitle(this.$message,'error','иҺ·еҸ–иҜ„д»·ж•°жҚ®еӨұиҙҘ').funtitle()\n\t\t\t} finally {\n\t\t\t\tthis.loading = false\n\t\t\t}\n\t\t},\n\t\t// жҗңзҙўиҜ„еҲҶ\n\t\tsearchRating() {\n\t\t\tif (this.selectedRating) {\n\t\t\t\tthis.filteredRatingList = this.ratingList.filter(item => item.rating == this.selectedRating)\n\t\t\t} else {\n\t\t\t\tthis.filteredRatingList = [...this.ratingList]\n\t\t\t}\n\t\t}\r\n\t},\r\n\tcreated() {\r\n\t\t// иҺ·еҸ–и®ўеҚ•\r\n\t\tthis.obtainorder(0)\r\n\t\t// и®ўеҚ•жҸҗйҶ’\r\n\t\tthis.dingdan = localStorage.getItem(\"order_num\")\r\n\t\t// еҗҜеҠЁиҮӘеҠЁеҲ·ж–°\r\n\t\tthis.startAutoRefresh()\r\n\t},\r\n\tbeforeDestroy() {\r\n\t\t// з»„д»¶й”ҖжҜҒеүҚеҒңжӯўиҮӘеҠЁеҲ·ж–°\r\n\t\tthis.stopAutoRefresh()\r\n\t},\r\n\twatch: {\r\n\t\t// зӣ‘еҗ¬и®ўеҚ•жҸҗйҶ’\r\n\t\t\"$store.state.remind\"(newValue, oldValue) {\r\n\t\t\tthis.dingdan = newValue.num\r\n\t\t}\r\n\t},\r\n}\r\n</script>\r\n\r\n<style scoped=\"scoped\">\r\n@import url(\"../../../style/pubiss.css\");\r\n@import url(\"../../../style/popup.css\");\r\n::v-deep .el-pagination.is-background .el-pager li:not(.disabled).active {\r\n\tbackground-color: #00be06;\r\n\tcolor: #fff;\r\n}\r\n::v-deep .el-badge{\r\n\tmargin-right: 5px;\r\n}\r\n.menu-padd{\r\n\tborder-bottom: 1px solid #f8f8f8;\r\n}\r\n.Menu-details{\r\n\tdisplay: flex;\r\n\talign-items: center;\r\n\tjustify-content: space-between;\r\n\tpadding: 0 50px;\r\n}\r\n.menu-margin{margin: 20px 0;}\r\n.menu-span{\r\n\tfont-weight: bold;\r\n\tfont-size: 15px;\r\n\tpadding-top: 20px;\r\n}\r\n::v-deep .el-dialog{\r\n\theight: 600px;\r\n\toverflow-y: auto;\r\n\tborder-radius: 5px !important;\r\n}\r\n.order-detail-info {\r\n    padding: 15px;\r\n    background: #f5f7fa;\r\n    border-radius: 4px;\r\n    margin-bottom: 20px;\r\n}\r\n\r\n.info-item {\r\n    margin-bottom: 10px;\r\n    display: flex;\r\n    align-items: center;\r\n}\r\n\r\n.info-item .label {\r\n    color: #606266;\r\n    width: 80px;\r\n    text-align: right;\r\n    margin-right: 10px;\r\n}\r\n\r\n.info-item .value {\r\n    color: #303133;\r\n    flex: 1;\r\n}\r\n\r\n.menu-title {\r\n    font-size: 16px;\r\n    font-weight: bold;\r\n    color: #303133;\r\n    margin-bottom: 15px;\r\n    padding-left: 10px;\r\n    border-left: 3px solid #409EFF;\r\n}\r\n\r\n.menu-list {\r\n    max-height: 300px;\r\n    overflow-y: auto;\r\n}\r\n\r\n.menu-item {\r\n    padding: 10px;\r\n    border-bottom: 1px solid #EBEEF5;\r\n}\r\n\r\n.menu-detail {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n}\r\n\r\n.dish-name {\r\n    color: #303133;\r\n    font-size: 14px;\r\n}\r\n\r\n.dish-quantity {\r\n    color: #909399;\r\n    font-size: 14px;\r\n}\r\n\r\n/* иҜ„д»·з®ЎзҗҶж ·ејҸ */\r\n.rating-management {\r\n    padding: 20px 0;\r\n}\r\n\r\n.rating-stats {\r\n    margin-bottom: 30px;\r\n}\r\n\r\n.rating-stats h3,\r\n.rating-distribution h3,\r\n.rating-list h3 {\r\n    font-size: 16px;\r\n    font-weight: bold;\r\n    color: #303133;\r\n    margin-bottom: 15px;\r\n    padding-left: 10px;\r\n    border-left: 3px solid #409EFF;\r\n}\r\n\r\n.stats-grid {\r\n    display: grid;\r\n    grid-template-columns: repeat(4, 1fr);\r\n    gap: 20px;\r\n    margin-bottom: 20px;\r\n}\r\n\r\n.stat-item {\r\n    background: #f5f7fa;\r\n    padding: 20px;\r\n    border-radius: 4px;\r\n    text-align: center;\r\n}\r\n\r\n.stat-label {\r\n    color: #606266;\r\n    font-size: 14px;\r\n    margin-bottom: 10px;\r\n}\r\n\r\n.stat-value {\r\n    color: #303133;\r\n    font-size: 24px;\r\n    font-weight: bold;\r\n}\r\n\r\n.rating-distribution {\r\n    margin-bottom: 30px;\r\n}\r\n\r\n.distribution-bar {\r\n    background: #f5f7fa;\r\n    padding: 20px;\r\n    border-radius: 4px;\r\n}\r\n\r\n.bar-item {\r\n    display: flex;\r\n    align-items: center;\r\n    margin-bottom: 10px;\r\n}\r\n\r\n.bar-label {\r\n    width: 40px;\r\n    font-size: 14px;\r\n    color: #606266;\r\n}\r\n\r\n.bar-container {\r\n    flex: 1;\r\n    height: 20px;\r\n    background: #e4e7ed;\r\n    border-radius: 10px;\r\n    margin: 0 10px;\r\n    overflow: hidden;\r\n}\r\n\r\n.bar-fill {\r\n    height: 100%;\r\n    background: #409EFF;\r\n    transition: width 0.3s;\r\n}\r\n\r\n.bar-count {\r\n    width: 40px;\r\n    text-align: right;\r\n    font-size: 14px;\r\n    color: #606266;\r\n}\r\n\r\n.rating-list {\r\n    margin-top: 20px;\r\n}\r\n\r\n.el-table {\r\n    margin-top: 10px;\r\n}\r\n</style>\r\n"]}]}