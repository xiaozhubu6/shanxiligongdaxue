=\"width: 100%\">\n        <el-table-column\n          label=\"成本日期\"\n          width=\"120\">\n          <template slot-scope=\"scope\">\n            {{ $dayjs(scope.row.costDate).format('YYYY-MM-DD') }}\n          </template>\n        </el-table-column>\n        <el-table-column\n          prop=\"totalCost\"\n          label=\"总成本（元）\"\n          width=\"120\"\n          align=\"center\">\n        </el-table-column>\n        <el-table-column\n          prop=\"totalRevenue\"\n          label=\"总营业额（元）\"\n          width=\"120\"\n          align=\"center\">\n        </el-table-column>\n        <el-table-column\n          prop=\"profit\"\n          label=\"利润（元）\"\n          width=\"120\"\n          align=\"center\">\n          <template slot-scope=\"scope\">\n            <span :style=\"{color: scope.row.profit >= 0 ? 'green' : 'red', fontWeight: 'bold'}\">{{ scope.row.profit }}</span>\n          </template>\n        </el-table-column>\n        <el-table-column\n          label=\"成本明细\"\n          width=\"180\"\n          align=\"center\">\n          <template slot-scope=\"scope\">\n            <div v-if=\"scope.row.costDetail && isJson(scope.row.costDetail)\">\n              <div v-for=\"(v, k) in JSON.parse(scope.row.costDetail)\" :key=\"k\">{{ k }}：{{ v }} 元</div>\n            </div>\n            <div v-else>{{ scope.row.costDetail }}</div>\n          </template>\n        </el-table-column>\n        <el-table-column\n          prop=\"remark\"\n          label=\"备注\"\n          width=\"150\"\n          align=\"center\">\n        </el-table-column>\n        <el-table-column\n          label=\"操作\"\n          width=\"150\"\n          align=\"center\">\n          <template slot-scope=\"scope\">\n            <el-button\n              size=\"mini\"\n              type=\"primary\"\n              @click=\"handleEdit(scope.row)\">编辑</el-button>\n            <el-button\n              size=\"mini\"\n              type=\"danger\"\n              @click=\"handleDelete(scope.row)\">删除</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n      <!-- 分页 -->\n      <el-pagination\n        background\n        layout=\"prev, pager, next\"\n        :hide-on-single-page=\"true\"\n        :total=\"total\"\n        :current-page=\"currentPage\"\n        @current-change=\"handleCurrentChange\">\n      </el-pagination>\n      <!-- 添加/编辑对话框 -->\n      <el-dialog :title=\"dialogTitle\" :visible.sync=\"dialogVisible\" width=\"500px\">\n        <el-form :model=\"form\" :rules=\"rules\" ref=\"form\" label-width=\"100px\">\n          <el-form-item label=\"日期\" prop=\"costDate\">\n            <el-date-picker\n              v-model=\"form.costDate\"\n              type=\"date\"\n              placeholder=\"选择日期\"\n              value-format=\"yyyy-MM-dd\">\n            </el-date-picker>\n          </el-form-item>\n          <el-form-item label=\"食材成本\" prop=\"foodCost\">\n            <el-input v-model.number=\"form.foodCost\" placeholder=\"请输入食材成本\" type=\"number\" min=\"0\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"人工成本\" prop=\"laborCost\">\n            <el-input v-model.number=\"form.laborCost\" placeholder=\"请输入人工成本\" type=\"number\" min=\"0\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"水电成本\" prop=\"waterCost\">\n            <el-input v-model.number=\"form.waterCost\" placeholder=\"请输入水电成本\" type=\"number\" min=\"0\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"备注\" prop=\"remark\">\n            <el-input\n              type=\"textarea\"\n              v-model=\"form.remark\"\n              placeholder=\"请输入备注\">\n            </el-input>\n          </el-form-item>\n        </el-form>\n        <div slot=\"footer\" class=\"dialog-footer\">\n          <el-button @click=\"dialogVisible = false\">取 消</el-button>\n          <el-button type=\"primary\" @click=\"submitForm\">确 定</el-button>\n        </div>\n      </el-dialog>\n    </div>\n  </div>\n</div>\n",null]}