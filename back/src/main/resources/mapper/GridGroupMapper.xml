<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zhuqilong.back.mapper.GridGroupMapper">
    
    <resultMap id="BaseResultMap" type="com.zhuqilong.back.entity.GridGroup">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="community_id" property="communityId" jdbcType="BIGINT"/>
        <result column="name" property="name" jdbcType="VARCHAR"/>
        <result column="unit_number" property="unitNumber" jdbcType="VARCHAR"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, community_id, name, unit_number, created_at
    </sql>

    <select id="selectAll" resultMap="BaseResultMap">
        select 
        <include refid="Base_Column_List" />
        from grid_group
        order by created_at desc
    </select>

    <select id="selectById" resultMap="BaseResultMap" parameterType="java.lang.Long">
        select 
        <include refid="Base_Column_List" />
        from grid_group
        where id = #{id,jdbcType=BIGINT}
    </select>

    <select id="selectByCommunityId" resultMap="BaseResultMap" parameterType="java.lang.Long">
        select 
        <include refid="Base_Column_List" />
        from grid_group
        where community_id = #{communityId,jdbcType=BIGINT}
        order by created_at desc
    </select>

    <delete id="deleteById" parameterType="java.lang.Long">
        delete from grid_group
        where id = #{id,jdbcType=BIGINT}
    </delete>

    <delete id="delete" parameterType="com.zhuqilong.back.entity.GridGroup">
        delete from grid_group
        where id = #{id,jdbcType=BIGINT}
    </delete>

</mapper>
