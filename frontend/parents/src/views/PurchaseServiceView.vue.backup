  transform: translateY(-5px);
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
}

.item-icon {
  margin-bottom: 15px;
  text-align: center;
}

.item-info h4 {
  margin: 0;
  color: #333;
  font-size: 18px;
}

.item-info .price {
  margin: 5px 0 0;
  color: #f56c6c;
  font-size: 20px;
  font-weight: 600;
}

.custom-input {
  margin-bottom: 30px;
}

.input-with-voice {
  position: relative;
}

.voice-controls {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 20px;
}

.voice-status {
  font-size: 14px;
  color: #666;
}

.custom-input {
  background: white;
  padding: 30px;
  border-radius: 15px;
  margin-bottom: 40px;
}

.custom-input h3 {
  color: #333;
  margin-bottom: 20px;
  font-size: 24px;
}

.input-actions {
  display: flex;
  align-items: center;
  gap: 15px;
}

.history {
  background: white;
  padding: 30px;
  border-radius: 15px;
}

.history h3 {
  color: #333;
  margin-bottom: 20px;
  font-size: 24px;
}

/* 老人端大字体优化 */
.el-textarea {
  font-size: 18px !important;
}

.el-input-number {
  font-size: 16px !important;
}

.el-button {
  font-size: 18px !important;
  padding: 12px 30px !important;
}

